---
import Layout from '../layouts/Layout.astro';

const tickerTags = [
	'Digitaalinen markkinointi',
	'Brändi',
	'Valokuvaus',
	'Videot',
	'Editointi',
	'Verkkosivut',
	'Tekoälyn integrointi',
	'Sosiaalinen media',
	'Graafinen suunnittelu',
	'Markkinoinnin johtaminen',
];
const tickerRepeats = [0, 1, 2, 3];
---

<Layout>
	<div class="cursor-light" aria-hidden="true"></div>

	<header class="masthead">
		<a href="#top" class="brand">
			<span class="brand-mark">KK</span>
			<span class="brand-name">KOPEPIX</span>
		</a>
		<nav>
			<a href="#profile">Profiili</a>
			<a href="#experience">Kokemus</a>
			<a href="#skills">Osaaminen</a>
			<a href="#work">Työt</a>
			<a href="#contact" class="nav-cta">Ota yhteyttä</a>
		</nav>
	</header>

	<main id="top">
		<!-- ========== HERO ========== -->
		<section class="hero">
			<div class="hero-bg" aria-hidden="true">
				<div class="hero-halo"></div>
				<div class="hero-grid"></div>
			</div>

			<div class="hero-stack" data-parallax-host>
				<h1 class="hero-layer hero-layer--back" aria-label="Konsta Kivioja Portfolio" data-depth="0">
					<span class="hero-line hero-line--top">KONSTA KIVIOJA</span>
					<span class="hero-line hero-line--bottom">PORTFOLIO</span>
				</h1>

				<div class="hero-layer hero-layer--photo" aria-hidden="true" data-depth="1.2">
					<img src="/hero-cutout.png" onerror="this.src='/hero.jpg'; this.classList.add('hero-photo-fallback');" alt="" />
				</div>

				<div class="hero-layer hero-layer--front" aria-hidden="true" data-depth="0">
					<span class="hero-line hero-line--top">KONSTA KIVIOJA</span>
					<span class="hero-line hero-line--bottom" aria-hidden="true">PORTFOLIO</span>
				</div>
			</div>

			<div class="hero-ticker" aria-hidden="true">
				<div class="hero-ticker-track">
					{tickerRepeats.map(() => tickerTags.map((tag) => (
						<span class="ticker-tag">{tag}</span>
					)))}
				</div>
			</div>
		</section>

		<!-- ========== STANDFIRST / MANIFESTO ========== -->
		<section class="band band--standfirst">
			<p class="standfirst" data-reveal>
				<span class="word">Rakennan</span> <span class="word">visuaalisesti</span>
				<span class="word">vahvan</span> <span class="word">markkinointi&shy;kokemuksen,</span>
				<span class="word">joka</span> <span class="word">yhdistää</span>
				<span class="word">videon,</span> <span class="word">brändin</span>
				<span class="word">ja</span> <span class="word">digitaalisen</span>
				<span class="word">tarinankerronnan.</span>
			</p>
			<div class="standfirst-actions">
				<a href="#work" class="button primary">Katso työt</a>
				<a href="#contact" class="button ghost">Ota yhteyttä</a>
			</div>
		</section>

		<!-- ========== 01 — PROFIILI ========== -->
		<section id="profile" class="band band--split" data-section="01" data-section-name="Profiili">
			<header class="band-head" data-reveal>
				<span class="band-num">01 / Profiili</span>
				<h2 class="display">Markkinointi&shy;päällikkö</h2>
			</header>
			<div class="band-body">
				<p class="lead" data-reveal>
					Moniosaaja, joka näkee visuaalisuuden ja myynnin samana koneena. Olen johtanut
					kasvuyrityksen markkinointia menestyksekkäästi vähillä resursseilla — tuloksia
					tehdään suunnitelmalla, ei budjetilla.
				</p>
				<p class="prose" data-reveal>
					Runsaasti kokemusta yhteistyöstä myyntitiimin kanssa tavoitteiden saavuttamiseksi.
					Pätevä laatimaan markkinointisuunnitelmia, jotka vastaavat yrityksen strategiaa.
					Uusien asioiden opettelu enemmän innostaa kuin lannistaa minua.
				</p>
				<dl class="pillars" data-reveal>
					<div class="pillar">
						<dt><span class="pillar-num">01</span> Strategia</dt>
						<dd>Ymmärrän tavoitteesi ja sparraan sisältöä, joka toimii.</dd>
					</div>
					<div class="pillar">
						<dt><span class="pillar-num">02</span> Visuaalisuus</dt>
						<dd>Laadukas jälki tekee brändistäsi tunnistettavan.</dd>
					</div>
					<div class="pillar">
						<dt><span class="pillar-num">03</span> Tulos</dt>
						<dd>Julkaisut on tehty vaikuttaviksi ja konvertoiviksi.</dd>
					</div>
				</dl>
			</div>
		</section>

		<!-- ========== 02 — KOKEMUS & KOULUTUS ========== -->
		<section id="experience" class="band band--split" data-section="02" data-section-name="Kokemus">
			<header class="band-head" data-reveal>
				<span class="band-num">02 / Kokemus</span>
				<h2 class="display">Työpolku<br />ja koulutus</h2>
			</header>
			<div class="band-body two-col">
				<div class="col" data-reveal>
					<span class="col-label">Työkokemus</span>
					<ol class="entries">
						<li>
							<span class="entry-role">Markkinointipäällikkö</span>
							<span class="entry-org">Anfra Oy</span>
						</li>
						<li>
							<span class="entry-role">Varastotyöntekijä</span>
							<span class="entry-org">Pro Nutrition Finland Oy</span>
						</li>
						<li>
							<span class="entry-role">Myyjä</span>
							<span class="entry-org">Lämpöykkönen Oy</span>
						</li>
						<li>
							<span class="entry-role">Jakaja</span>
							<span class="entry-org">Kaleva</span>
						</li>
						<li>
							<span class="entry-role">Hormisaneeraaja · kenttämyyjä</span>
							<span class="entry-org">Fixi Oy</span>
						</li>
						<li>
							<span class="entry-role">Puhelinbuukkari</span>
							<span class="entry-org">Pisaron Oy</span>
						</li>
					</ol>
				</div>
				<div class="col" data-reveal>
					<span class="col-label">Koulutus</span>
					<ol class="entries">
						<li>
							<span class="entry-role">Digimarkkinoinnin perusteet</span>
							<span class="entry-org">Google Digital Garage · 2022</span>
						</li>
						<li>
							<span class="entry-role">Digital Excellence Academy</span>
							<span class="entry-org">Saranen Consulting · 2022</span>
						</li>
						<li>
							<span class="entry-role">Ylioppilas</span>
							<span class="entry-org">Haukiputaan lukio · 2015</span>
						</li>
						<li>
							<span class="entry-role">Liikunta- ja tutor-koulutus</span>
							<span class="entry-org">Haukiputaan lukio</span>
						</li>
					</ol>
				</div>
			</div>
		</section>

		<!-- ========== 03 — OSAAMINEN ========== -->
		<section id="skills" class="band band--split" data-section="03" data-section-name="Osaaminen">
			<header class="band-head" data-reveal>
				<span class="band-num">03 / Osaaminen</span>
				<h2 class="display">Mitä osaan<br />tehdä sinulle</h2>
			</header>
			<div class="band-body two-col">
				<div class="col" data-reveal>
					<span class="col-label">Markkinointi</span>
					<ul class="chips">
						<li>Markkinoinnin johtaminen</li>
						<li>Verkkosivujen teko ja päivitys</li>
						<li>Sosiaalinen media</li>
						<li>Somemainonta</li>
						<li>Video- ja kuvaeditointi</li>
						<li>Graafinen suunnittelu</li>
						<li>Tekoälyn käyttö markkinoinnissa</li>
						<li>Ja paljon muuta</li>
					</ul>
				</div>
				<div class="col" data-reveal>
					<span class="col-label">Ohjelmistot</span>
					<ul class="chips">
						<li>Photoshop</li>
						<li>Lightroom</li>
						<li>DaVinci Resolve</li>
						<li>ChatGPT &amp; Gemini</li>
						<li>Midjourney</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- ========== 04 — VALITUT TYÖT ========== -->
		<section id="work" class="band band--work" data-section="04" data-section-name="Työt">
			<header class="band-head" data-reveal>
				<span class="band-num">04 / Valitut työt</span>
				<h2 class="display">Tuoreimmat<br />projektit</h2>
			</header>
			<div class="work-list">
				<a class="work" href="https://youtu.be/rQkSkqKakRA?feature=shared" target="_blank" rel="noopener" data-reveal>
					<span class="work-index">N° 01</span>
					<div class="work-meta">
						<span class="work-tag">Video</span>
						<h3>Suunnittelu ja toteutus työntekijöiden uratarinoille</h3>
						<p>Tuotantoa, käsikirjoitus ja editointi alusta loppuun.</p>
					</div>
					<span class="work-cta">
						Katso video
						<svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
							<path d="M3 11L11 3M11 3H4M11 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"></path>
						</svg>
					</span>
				</a>
				<a class="work" href="https://anfra-aidat.fi/" target="_blank" rel="noopener" data-reveal>
					<span class="work-index">N° 02</span>
					<div class="work-meta">
						<span class="work-tag">Brändi</span>
						<h3>Anfra-Aitojen brändi ja verkkosivut</h3>
						<p>Anfra-Aitojen brändin, verkkosivujen ja mainonnan rakentaminen alusta loppuun.</p>
					</div>
					<span class="work-cta">
						Avaa sivu
						<svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
							<path d="M3 11L11 3M11 3H4M11 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"></path>
						</svg>
					</span>
				</a>
				<div class="work" data-reveal>
					<span class="work-index">N° 03</span>
					<div class="work-meta">
						<span class="work-tag">AI · Kuvapankki</span>
						<h3>Brändikuvapankki tekoälyllä</h3>
						<p>Brändikuvapankin luonti Midjourneyn avulla — tunnistettava jälki ilman kuvauspäivän kuluja.</p>
					</div>
					<span class="work-cta inert">Case study tulossa</span>
				</div>
			</div>
		</section>

		<!-- ========== 05 — YHTEYS ========== -->
		<section id="contact" class="band band--contact" data-section="05" data-section-name="Yhteys">
			<div class="contact-stage" data-reveal>
				<span class="band-num">05 / Yhteys</span>
				<h2 class="display contact-display">Tehdäänkö<br />yhdessä?</h2>
				<p class="contact-lead">
					Olipa kyse brändistä, verkkosivuista tai videosta — ole rohkeasti yhteydessä.
				</p>
				<div class="contact-grid">
					<a class="contact-card" href="mailto:konstakivioja@gmail.com">
						<span class="contact-label">Email</span>
						<strong>konstakivioja@gmail.com</strong>
						<span class="contact-arrow" aria-hidden="true">→</span>
					</a>
					<a class="contact-card" href="tel:+358401409823">
						<span class="contact-label">Puhelin</span>
						<strong>040 140 9823</strong>
						<span class="contact-arrow" aria-hidden="true">→</span>
					</a>
				</div>
			</div>

			<footer class="colophon">
				<span>© 2026 Konsta Kivioja · Kopepix</span>
				<a href="#top">Takaisin ylös ↑</a>
				<a class="license-link" href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>
			</footer>
		</section>
	</main>
</Layout>

<style>
	:root {
		color-scheme: dark;
		--bg-0: #02050f;
		--bg-1: #04091f;
		--bg-2: #07112a;
		--ink-hi: #f4f6fb;
		--ink-mid: #c4cee0;
		--ink-low: #8895ad;
		--ink-faint: #4a546b;
		--accent: #6cd2ff;
		--rule: rgba(255, 255, 255, 0.08);
		--font-sans: 'Inter', 'Segoe UI', system-ui, sans-serif;
		--font-mono: 'JetBrains Mono', ui-monospace, 'Cascadia Code', monospace;
	}

	html {
		scroll-behavior: smooth;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		min-height: 100%;
		font-family: var(--font-sans);
		background: var(--bg-1);
		color: var(--ink-hi);
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}

	body {
		overflow-x: clip;
	}

	::selection {
		background: var(--accent);
		color: var(--bg-0);
	}

	main {
		position: relative;
		z-index: 1;
	}

	/* ========== CURSOR LIGHT ========== */
	.cursor-light {
		position: fixed;
		top: 0;
		left: 0;
		width: 560px;
		height: 560px;
		margin: -280px 0 0 -280px;
		background: radial-gradient(
			circle,
			rgba(125, 211, 252, 0.18) 0%,
			rgba(56, 189, 248, 0.08) 30%,
			transparent 70%
		);
		pointer-events: none;
		z-index: 60;
		mix-blend-mode: screen;
		transition: opacity 200ms ease-out;
		will-change: transform;
		opacity: 0;
	}

	.cursor-light.active {
		opacity: 1;
	}

	/* ========== MASTHEAD ========== */
	.masthead {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.2rem clamp(1.2rem, 4vw, 3rem);
		background: linear-gradient(180deg, rgba(2, 5, 15, 0.7), rgba(2, 5, 15, 0.1));
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		color: var(--ink-hi);
		text-decoration: none;
	}

	.brand-mark {
		display: inline-flex;
		justify-content: center;
		align-items: center;
		width: 30px;
		height: 30px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 50%;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 500;
	}

	.brand-name {
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.18em;
	}

	.masthead nav {
		display: flex;
		gap: 1.6rem;
		align-items: center;
	}

	.masthead nav a {
		color: var(--ink-mid);
		text-decoration: none;
		font-size: 0.84rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		transition: color 180ms ease;
	}

	.masthead nav a:hover {
		color: var(--accent);
	}

	.nav-cta {
		padding: 0.55rem 1rem;
		border: 1px solid rgba(108, 210, 255, 0.4);
		border-radius: 999px;
		color: var(--accent) !important;
	}

	.nav-cta:hover {
		background: rgba(108, 210, 255, 0.12);
	}

	@media (max-width: 760px) {
		.masthead nav a:not(.nav-cta) {
			display: none;
		}
	}

	/* ========== SCROLL TAG (left side) ========== */
	.scroll-tag {
		position: fixed;
		left: clamp(0.8rem, 1.8vw, 1.8rem);
		top: 50%;
		transform: translateY(-50%) rotate(-90deg);
		transform-origin: left center;
		z-index: 40;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.32em;
		text-transform: uppercase;
		color: var(--ink-low);
		pointer-events: none;
	}

	.tag-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 12px var(--accent);
	}

	@media (max-width: 1000px) {
		.scroll-tag {
			display: none;
		}
	}

	/* ========== HERO ========== */
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: clamp(4rem, 5.5vw, 5rem) clamp(1.5rem, 4vw, 3rem) 4rem;
		overflow: hidden;
		isolation: isolate;
		--mx: 0;
		--my: 0;
	}

	/* Backdrop: halo glow + faint grid */
	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
	}

	.hero-halo {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 90vmin;
		height: 90vmin;
		transform: translate(-50%, -50%) translate3d(calc(var(--mx) * 18px), calc(var(--my) * 18px), 0);
		background:
			radial-gradient(circle at 50% 50%, rgba(108, 210, 255, 0.16) 0%, rgba(108, 210, 255, 0.06) 30%, transparent 65%),
			radial-gradient(circle at 50% 50%, rgba(56, 189, 248, 0.05) 0%, transparent 70%);
		filter: blur(40px);
		opacity: 0.95;
		transition: transform 600ms cubic-bezier(0.2, 0.7, 0.2, 1);
	}

	.hero-grid {
		position: absolute;
		inset: -2px;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
		background-size: clamp(40px, 5vw, 64px) clamp(40px, 5vw, 64px);
		mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.7) 60%, #000 100%);
		-webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.7) 60%, #000 100%);
		opacity: 0.6;
	}

	.hero-stack {
		position: relative;
		width: 100%;
		max-width: 1400px;
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;
		justify-items: center;
		align-items: end;
	}

	.hero-layer {
		grid-column: 1;
		grid-row: 1;
		width: 100%;
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.05em;
		text-align: center;
		font-weight: 900;
		letter-spacing: -0.045em;
		line-height: 0.88;
		transform: translate3d(calc(var(--mx) * var(--depth, 0) * 14px), calc(var(--my) * var(--depth, 0) * 14px), 0);
		transition: transform 380ms cubic-bezier(0.2, 0.7, 0.2, 1);
	}

	.hero-line {
		display: block;
		white-space: nowrap;
		font-size: clamp(2.4rem, 10.48vw, 10.5rem);
	}

	.hero-line--top {
		font-family: 'Saira Stencil One', 'Inter', sans-serif;
		font-weight: 400;
		letter-spacing: 0;
	}

	.hero-line--bottom {
		font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
		font-weight: 900;
		letter-spacing: -0.06em;
		font-size: clamp(3.6rem, 16vw, 16rem);
		line-height: 0.82;
	}

	/* Layer 1: solid white KONSTA — sits behind the cutout photo so person blocks it visually */
	.hero-layer--back .hero-line--top {
		color: #ffffff;
	}

	/* PORTFOLIO on the back layer is a structural placeholder — actual PORTFOLIO sits on the front layer */
	.hero-layer--back .hero-line--bottom {
		visibility: hidden;
	}

	/* Layer 3: stencil outline ONLY for KONSTA KIVIOJA — shows where it overlaps the photo */
	.hero-layer--front .hero-line--top {
		color: transparent;
		-webkit-text-stroke: 1.8px #ffffff;
		text-stroke: 1.8px #ffffff;
	}

	/* PORTFOLIO sits on the FRONT layer — fully visible on top of the photo */
	.hero-layer--front .hero-line--bottom {
		visibility: visible;
		color: #ffffff;
		-webkit-text-stroke: 0;
		text-stroke: 0;
	}

	@media (max-width: 720px) {
		.hero-layer--front .hero-line--top {
			-webkit-text-stroke-width: 1px;
		}
	}

	/* Layer 2: person photo — bottom-aligned to grid cell so its bottom lines up with PORTFOLIO baseline */
	.hero-layer--photo {
		pointer-events: none;
		align-items: center;
		justify-content: flex-end;
		height: auto;
	}

	.hero-layer--photo img {
		display: block;
		width: auto;
		height: clamp(780px, 118vh, 1240px);
		max-width: 96vw;
		object-fit: contain;
		object-position: bottom;
		filter:
			grayscale(0.9)
			contrast(1.35)
			brightness(0.62)
			drop-shadow(0 30px 60px rgba(0, 0, 0, 0.55));
	}

	/* When fallback JPG used: fade edges via radial mask so white bg disappears */
	.hero-layer--photo img.hero-photo-fallback {
		filter: grayscale(0.55) contrast(1.08) brightness(0.92) saturate(0.6);
		-webkit-mask-image: radial-gradient(
			ellipse 52% 70% at 50% 42%,
			#000 24%,
			#000 52%,
			rgba(0, 0, 0, 0.6) 72%,
			transparent 95%
		);
		mask-image: radial-gradient(
			ellipse 52% 70% at 50% 42%,
			#000 24%,
			#000 52%,
