---
import Layout from '../layouts/Layout.astro';

const tickerTags = [
	'Digitaalinen markkinointi',
	'Brändi',
	'Valokuvaus',
	'Videot',
	'Editointi',
	'Verkkosivut',
	'Tekoälyn integrointi',
	'Sosiaalinen media',
	'Graafinen suunnittelu',
	'Markkinoinnin johtaminen',
];
const tickerRepeats = [0, 1, 2, 3];

// Vertical KOPEPIX side-mark — alternating solid + outline copies
const verticalCount = 8;
---

<Layout>
	<a class="skip-link" href="#top">Siirry sisältöön</a>
	<div class="cursor-light" aria-hidden="true"></div>

	<header class="masthead">
		<a href="#top" class="brand">
			<span class="brand-mark">KK</span>
			<span class="brand-name">Konsta Kivioja <span class="brand-name-suffix">Portfolio</span></span>
		</a>
		<nav>
			<a href="#profile">Profiili</a>
			<a href="#experience">Kokemus</a>
			<a href="#skills">Osaaminen</a>
			<a href="#work">Työt</a>
			<a href="#contact" class="nav-cta">Ota yhteyttä</a>
		</nav>
	</header>

	<main id="top">
		<!-- ========== HERO ========== -->
		<section class="hero">
			<div class="hero-bg" aria-hidden="true">
				<div class="hero-halo"></div>
			</div>

			<div class="hero-stack">
				<h1 class="hero-layer hero-layer--back" aria-label="Konsta Kivioja Portfolio">
					<span class="hero-line hero-line--top">KONSTA KIVIOJA</span>
					<span class="hero-line hero-line--bottom">PORTFOLIO</span>
				</h1>

				<div class="hero-layer hero-layer--photo" aria-hidden="true">
					<picture>
						<source srcset="/hero-cutout.webp" type="image/webp" />
						<img
							src="/hero-cutout.png"
							onerror="this.src='/hero.jpg'; this.classList.add('hero-photo-fallback');"
							alt=""
							decoding="async"
							fetchpriority="high"
						/>
					</picture>
				</div>

				<div class="hero-layer hero-layer--front" aria-hidden="true">
					<span class="hero-line hero-line--top">KONSTA KIVIOJA</span>
					<span class="hero-line hero-line--bottom" aria-hidden="true">PORTFOLIO</span>
				</div>
			</div>

			<div class="hero-ticker" aria-hidden="true">
				<div class="hero-ticker-track">
					{tickerRepeats.map(() => tickerTags.map((tag) => (
						<span class="ticker-tag">{tag}</span>
					)))}
				</div>
			</div>
		</section>

		<div class="post-hero">
			<aside class="vertical-mark" aria-hidden="true">
				{Array.from({ length: verticalCount }).map((_, i) => (
					<span class={`vertical-text ${i % 2 === 0 ? 'vertical-text--solid' : 'vertical-text--outline'}`}>KOPEPIX</span>
				))}
			</aside>

		<!-- ========== PROFIILI ========== -->
		<section id="profile" class="band band--standfirst" data-section="01" data-section-name="Profiili">
			<h2 class="display" data-reveal>Profiili</h2>
			<p class="standfirst" data-reveal data-reveal-tier="primary">
				<span class="word">Markkinoinnin</span> <span class="word">moniosaaja.</span>
				<span class="word">Runsaasti</span> <span class="word">kokemusta</span>
				<span class="word">yhteistyöstä</span> <span class="word">myyntitiimin</span>
				<span class="word">kanssa</span> <span class="word">tavoitteiden</span>
				<span class="word">saavuttamiseksi.</span> <span class="word">Olen</span>
				<span class="word">pätevä</span> <span class="word">laatimaan</span>
				<span class="word">markkinointi&shy;suunnitelmia,</span> <span class="word">jotka</span>
				<span class="word">vastaavat</span> <span class="word">yrityksen</span>
				<span class="word">strategiaa.</span> <span class="word">Olen</span>
				<span class="word">johtanut</span> <span class="word">kasvuyrityksen</span>
				<span class="word">ja</span> <span class="word">sen</span>
				<span class="word">aputoiminimen</span> <span class="word">markkinointia</span>
				<span class="word">menestyksekkäästi</span> <span class="word">vähillä</span>
				<span class="word">resursseilla.</span> <span class="word">Tekoälyn</span>
				<span class="word">osalta</span> <span class="word">olen</span>
				<span class="word">hyvin</span> <span class="word">perillä</span>
				<span class="word">tämän</span> <span class="word">hetken</span>
				<span class="word">mahdollisuuksista</span> <span class="word">ja</span>
				<span class="word">olen</span> <span class="word">kokeillut</span>
				<span class="word">kymmeniä</span> <span class="word">eri</span>
				<span class="word">tekoälytyökaluja.</span> <span class="word">Tarjoan</span>
				<span class="word">markkinointipalveluja</span> <span class="word">nimellä</span>
				<span class="word">KopePix.</span>
			</p>
			<div class="standfirst-actions">
				<a href="#work" class="button primary">Katso työt</a>
				<a href="#contact" class="button ghost">Ota yhteyttä</a>
			</div>
		</section>

		<!-- ========== 03 — OSAAMINEN ========== -->
		<section id="skills" class="band band--split" data-section="03" data-section-name="Osaaminen">
			<header class="band-head" data-reveal>
				<span class="band-num">03 / Osaaminen</span>
				<h2 class="display">Mitä osaan</h2>
			</header>
			<div class="band-body two-col">
				<div class="col" data-reveal>
					<h3 class="col-label">Markkinointi</h3>
					<ul class="chips">
						<li>Markkinoinnin johtaminen</li>
						<li>Tekoälyn käyttö markkinoinnissa</li>
						<li>Verkkosivujen teko ja päivitys</li>
						<li>Sosiaalinen media</li>
						<li>Somemainonta</li>
						<li>Video- ja kuvaeditointi</li>
						<li>Graafinen suunnittelu</li>
						<li>Ja paljon muuta</li>
					</ul>
				</div>
				<div class="col" data-reveal>
					<h3 class="col-label">Ohjelmistot</h3>
					<ul class="chips">
						<li>Photoshop</li>
						<li>Lightroom</li>
						<li>DaVinci Resolve</li>
						<li>ChatGPT &amp; Gemini</li>
						<li>Midjourney</li>
						<li>Claude Code</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- ========== 04 — VALITUT TYÖT ========== -->
		<section id="work" class="band band--work" data-section="04" data-section-name="Työt">
			<header class="band-head" data-reveal>
				<span class="band-num">04 / Valitut työt</span>
				<h2 class="display">Tuoreimmat<br />projektit</h2>
			</header>
			<div class="work-list">
				<div class="work" data-reveal>
					<span class="work-index">N° 01</span>
					<div class="work-meta">
						<span class="work-tag">Verkkosivut · AI</span>
						<h3>Tämä sivusto, koodattu Claude Codella</h3>
						<p>Portfolio-sivusto on rakennettu Astrolla ja koodattu kokonaan Claudea käyttäen.</p>
					</div>
					<span class="work-cta inert">Katsot juuri nyt</span>
				</div>
				<a class="work" href="https://www.youtube.com/@KDFloorball" target="_blank" rel="noopener" data-reveal>
					<span class="work-index">N° 02</span>
					<div class="work-meta">
						<span class="work-tag">Videoeditointi</span>
						<h3>Salibandymaajoukkueiden aftermoviet</h3>
						<p>Ottelu-aftermovieiden editointi YouTube-kanavalle. Lisäksi maalikoosteita editoitu noin 1000 kappaletta.</p>
					</div>
					<span class="work-cta">
						Avaa kanava
						<svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
							<path d="M3 11L11 3M11 3H4M11 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"></path>
						</svg>
					</span>
				</a>
				<a class="work" href="https://youtu.be/rQkSkqKakRA?feature=shared" target="_blank" rel="noopener" data-reveal>
					<span class="work-index">N° 03</span>
					<div class="work-meta">
						<span class="work-tag">Video</span>
						<h3>Suunnittelu ja toteutus työntekijöiden uratarinoille</h3>
						<p>Tuotantoa, käsikirjoitus ja editointi alusta loppuun.</p>
					</div>
					<span class="work-cta">
						Katso video
						<svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
							<path d="M3 11L11 3M11 3H4M11 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"></path>
						</svg>
					</span>
				</a>
				<a class="work" href="https://anfra-aidat.fi/" target="_blank" rel="noopener" data-reveal>
					<span class="work-index">N° 04</span>
					<div class="work-meta">
						<span class="work-tag">Brändi</span>
						<h3>Anfra-Aitojen brändi ja verkkosivut</h3>
						<p>Anfra-Aitojen brändin, verkkosivujen ja mainonnan rakentaminen alusta loppuun.</p>
					</div>
					<span class="work-cta">
						Avaa sivu
						<svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
							<path d="M3 11L11 3M11 3H4M11 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"></path>
						</svg>
					</span>
				</a>
				<div class="work" data-reveal>
					<span class="work-index">N° 05</span>
					<div class="work-meta">
						<span class="work-tag">AI · Kuvapankki</span>
						<h3>Brändikuvapankki tekoälyllä</h3>
						<p>Brändikuvapankin luonti Midjourneyn avulla — tunnistettava jälki ilman kuvauspäivän kuluja.</p>
					</div>
					<span class="work-cta inert">Case study tulossa</span>
				</div>
			</div>
		</section>

		<!-- ========== 04 — KOKEMUS & KOULUTUS ========== -->
		<section id="experience" class="band band--split" data-section="04" data-section-name="Kokemus">
			<header class="band-head" data-reveal>
				<span class="band-num">04 / Kokemus</span>
				<h2 class="display">Työpolku<br />ja koulutus</h2>
			</header>
			<div class="band-body two-col">
				<div class="col" data-reveal>
					<h3 class="col-label">Työkokemus</h3>
					<ol class="entries">
						<li>
							<span class="entry-role">Markkinointipäällikkö</span>
							<span class="entry-org">Anfra Oy · 10/2022 – 2/2026</span>
						</li>
						<li>
							<span class="entry-role">Varastotyöntekijä</span>
							<span class="entry-org">Pro Nutrition Finland Oy · 8/2021 – 5/2022</span>
						</li>
						<li>
							<span class="entry-role">Myyjä</span>
							<span class="entry-org">Lämpöykkönen Oy · 2/2020 – 8/2020</span>
						</li>
						<li>
							<span class="entry-role">Jakaja</span>
							<span class="entry-org">Kaleva · 11/2018 – 2/2020</span>
						</li>
						<li>
							<span class="entry-role">Savuhormien pinnoittaja · myyjä</span>
							<span class="entry-org">Fixi Oy · 8/2017 – 10/2018</span>
						</li>
						<li>
							<span class="entry-role">Puhelinbuukkari</span>
							<span class="entry-org">Pisaron Oy</span>
						</li>
					</ol>
				</div>
				<div class="col" data-reveal>
					<h3 class="col-label">Koulutus</h3>
					<ol class="entries">
						<li>
							<span class="entry-role">Digimarkkinoinnin perusteet</span>
							<span class="entry-org">Google Digital Garage · 2022</span>
						</li>
						<li>
							<span class="entry-role">Digital Excellence Academy</span>
							<span class="entry-org">Saranen Consulting · 2022</span>
						</li>
						<li>
							<span class="entry-role">Ylioppilas</span>
							<span class="entry-org">Haukiputaan lukio · 2011–2015</span>
						</li>
						<li>
							<span class="entry-role">Liikunta- ja tutor-koulutus</span>
							<span class="entry-org">Haukiputaan lukio</span>
						</li>
					</ol>
				</div>
			</div>
		</section>

		<!-- ========== 05 — YHTEYS ========== -->
		<section id="contact" class="band band--contact" data-section="05" data-section-name="Yhteys">
			<div class="contact-stage" data-reveal>
				<span class="band-num">05 / Yhteys</span>
				<h2 class="display contact-display">Tehdäänkö<br />yhdessä?</h2>
				<p class="contact-lead">
					Olipa kyse mistä tahansa markkinoinnin projektista niin ole rohkeasti yhteydessä.
				</p>
				<div class="contact-grid">
					<a class="contact-card" href="mailto:konstakivioja@gmail.com">
						<span class="contact-label">Email</span>
						<strong>konstakivioja@gmail.com</strong>
						<span class="contact-arrow" aria-hidden="true">→</span>
					</a>
					<a class="contact-card" href="tel:+358401409823">
						<span class="contact-label">Puhelin</span>
						<strong>040 140 9823</strong>
						<span class="contact-arrow" aria-hidden="true">→</span>
					</a>
				</div>
			</div>

			<footer class="colophon">
				<span>© 2026 Konsta Kivioja · Kopepix</span>
				<a href="#top">Takaisin ylös ↑</a>
				<a class="license-link" href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>
			</footer>
		</section>
		</div>
	</main>
</Layout>

<style>
	:root {
		color-scheme: dark;
		--bg-0: #02050f;
		--bg-1: #04091f;
		--bg-2: #07112a;
		--ink-hi: #f4f6fb;
		--ink-mid: #c4cee0;
		--ink-low: #8895ad;
		/* Bumped from #4a546b to meet WCAG AA (4.5:1) for small text on --bg-1 */
		--ink-faint: #6b7691;
		--accent: #6cd2ff;
		--rule: rgba(255, 255, 255, 0.08);
		/* Body: Bricolage Grotesque (off the reflex-reject list, variable axes) */
		--font-sans: 'Bricolage Grotesque', 'Segoe UI', system-ui, sans-serif;
		/* Heavy display weight for PORTFOLIO — Inter Black is committed brand move at huge size */
		--font-display: 'Inter', 'Segoe UI', system-ui, sans-serif;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	/* Animatable custom properties — enables CSS-native interpolation when transitions are added later */
	@property --ticker-x {
		syntax: '<number>';
		inherits: false;
		initial-value: 0;
	}

	html {
		scroll-behavior: smooth;
		/* Offset anchor-link scrolling so target sections clear the fixed masthead */
		scroll-padding-top: 6rem;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		min-height: 100%;
		font-family: var(--font-sans);
		background: var(--bg-1);
		color: var(--ink-hi);
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}

	body {
		overflow-x: clip;
		--side-rail: clamp(180px, 30vw, 500px);
		--vtext-thickness: clamp(7.2rem, 12vw, 13.5rem);
		--rail-side-gap: calc((var(--side-rail) - var(--vtext-thickness)) / 2);
	}

	.post-hero {
		position: relative;
		padding-left: var(--side-rail);
		padding-right: var(--rail-side-gap);
	}

	@media (max-width: 760px) {
		.post-hero {
			padding-left: 0;
			padding-right: 0;
		}
	}

	::selection {
		background: var(--accent);
		color: var(--bg-0);
	}

	main {
		position: relative;
		z-index: 1;
	}

	/* ========== VERTICAL KOPEPIX SIDE-MARK ========== */
	.vertical-mark {
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: var(--side-rail);
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		align-items: center;
		/* Top padding aligns the X letter (top of first rotated KOPEPIX) with standfirst text top.
		   Bottom padding is 0 — extra items at the bottom are allowed to clip. */
		padding-top: calc(clamp(2rem, 5vw, 4rem) + var(--vtext-thickness) * 1.635);
		padding-bottom: 0;
		/* Fixed DOM gap = visual_gap + (visual_height - DOM_height).
		   For Saira Stencil: visual_height ≈ font * 4.27, DOM_height = font.
		   So compensation = font * 3.27. Visual gap added on top (~150px) stays constant on every viewport. */
		gap: calc(150px + var(--vtext-thickness) * 3.27);
		pointer-events: none;
		opacity: 0.2;
		z-index: 4;
		overflow: hidden;
	}

	.vertical-text {
		font-family: 'Saira Stencil One', 'Inter', sans-serif;
		font-weight: 400;
		font-size: clamp(7.2rem, 12vw, 13.5rem);
		letter-spacing: 0;
		line-height: 1;
		white-space: nowrap;
		transform: rotate(-90deg);
		transform-origin: center center;
		flex-shrink: 0;
	}

	.vertical-text--solid {
		color: #ffffff;
	}

	.vertical-text--outline {
		color: transparent;
		-webkit-text-stroke: 2.5px #ffffff;
		text-stroke: 2.5px #ffffff;
	}

	@media (max-width: 760px) {
		.vertical-mark {
			display: none;
		}
	}

	/* ========== CURSOR LIGHT ========== */
	.cursor-light {
		position: fixed;
		top: 0;
		left: 0;
		width: 280px;
		height: 280px;
		margin: -140px 0 0 -140px;
		background: radial-gradient(
			circle,
			rgba(125, 211, 252, 0.18) 0%,
			rgba(56, 189, 248, 0.08) 30%,
			transparent 70%
		);
		pointer-events: none;
		z-index: 60;
		mix-blend-mode: screen;
		transition: opacity 200ms ease-out;
		will-change: transform;
		opacity: 0;
	}

	.cursor-light.active {
		opacity: 1;
	}

	/* ========== SKIP LINK (a11y) ========== */
	.skip-link {
		position: fixed;
		top: -100px;
		left: 1rem;
		z-index: 100;
		padding: 0.75rem 1.25rem;
		background: var(--accent);
		color: var(--bg-0);
		font-weight: 700;
		text-decoration: none;
		border-radius: 6px;
		transition: top 180ms ease;
	}
	.skip-link:focus {
		top: 1rem;
		outline: 2px solid var(--ink-hi);
		outline-offset: 2px;
	}

	/* ========== MASTHEAD ========== */
	/* Solid background — glassmorphism removed (was 'default mode' not purposeful) */
	.masthead {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.2rem clamp(1.2rem, 4vw, 3rem);
		background: var(--bg-1);
		border-bottom: 1px solid var(--rule);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		color: var(--ink-hi);
		text-decoration: none;
	}

	.brand-mark {
		display: inline-flex;
		justify-content: center;
		align-items: center;
		width: 30px;
		height: 30px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 50%;
		font-family: var(--font-sans);
		font-size: 0.7rem;
		font-weight: 500;
	}

	.brand-name {
		font-size: 0.86rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.brand-name-suffix {
		color: var(--ink-low);
		font-weight: 500;
		margin-left: 0.25rem;
	}

	@media (max-width: 560px) {
		.brand-name-suffix {
			display: none;
		}
	}

	@media (max-width: 380px) {
		.brand-name {
			display: none;
		}
	}

	.masthead nav {
		display: flex;
		gap: 1.6rem;
		align-items: center;
	}

	.masthead nav a {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		padding: 0.55rem 0.6rem;
		color: var(--ink-mid);
		text-decoration: none;
		font-size: 0.92rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		transition: color 180ms ease;
	}

	.masthead nav a:hover,
	.masthead nav a:focus-visible {
		color: var(--accent);
		outline: none;
	}

	.nav-cta {
		padding: 0.55rem 1rem;
		border: 1px solid rgba(108, 210, 255, 0.4);
		border-radius: 999px;
		color: var(--accent) !important;
	}

	.nav-cta:hover {
		background: rgba(108, 210, 255, 0.12);
	}

	@media (max-width: 760px) {
		.masthead nav a:not(.nav-cta) {
			display: none;
		}
	}

	/* ========== SCROLL TAG (left side) ========== */
	.scroll-tag {
		position: fixed;
		left: clamp(0.8rem, 1.8vw, 1.8rem);
		top: 50%;
		transform: translateY(-50%) rotate(-90deg);
		transform-origin: left center;
		z-index: 40;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--font-sans);
		font-size: 0.72rem;
		letter-spacing: 0.32em;
		text-transform: uppercase;
		color: var(--ink-low);
		pointer-events: none;
	}

	.tag-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 12px var(--accent);
	}

	@media (max-width: 1000px) {
		.scroll-tag {
			display: none;
		}
	}

	/* ========== HERO ========== */
	.hero {
		position: relative;
		height: 100vh; /* fallback */
		height: 100dvh; /* dynamic viewport — handles mobile URL bar collapse */
		min-height: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end; /* pin stack to bottom; photo extends upward toward masthead */
		align-items: center;
		padding: 0 clamp(1.5rem, 4vw, 3rem) clamp(3rem, 4vw, 4rem);
		overflow: hidden;
		isolation: isolate;
		--mx: 0;
		--my: 0;
	}

	@media (max-width: 760px) {
		.hero {
			height: auto;
			min-height: 0;
			justify-content: flex-start;
			padding: clamp(5.25rem, 18vw, 6rem) clamp(1rem, 4vw, 2rem) clamp(3rem, 6vw, 4rem);
		}
	}

	/* Backdrop: halo glow + faint grid */
	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
	}

	.hero-halo {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 90vmin;
		height: 90vmin;
		transform: translate(-50%, -50%);
		background:
			radial-gradient(circle at 50% 50%, rgba(108, 210, 255, 0.16) 0%, rgba(108, 210, 255, 0.06) 30%, transparent 65%),
			radial-gradient(circle at 50% 50%, rgba(56, 189, 248, 0.05) 0%, transparent 70%);
		filter: blur(40px);
		opacity: 0.95;
		transition: transform 600ms cubic-bezier(0.2, 0.7, 0.2, 1);
	}


	.hero-stack {
		position: relative;
		width: 100%;
		max-width: 1400px;
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;
		justify-items: center;
		align-items: end;
	}

	.hero-layer {
		grid-column: 1;
		grid-row: 1;
		width: 100%;
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.05em;
		text-align: center;
		font-weight: 900;
		letter-spacing: -0.045em;
		line-height: 0.88;
	}

	.hero-line {
		display: block;
		white-space: nowrap;
		/* Scales with whichever is smaller — viewport width or height — so face clears text on short viewports.
		   Sized so KONSTA top reaches the t-shirt collar area. */
		font-size: clamp(1.7rem, min(8.9vw, 15.5vh), 9rem);
	}

	.hero-line--top {
		font-family: 'Saira Stencil One', 'Inter', sans-serif;
		font-weight: 400;
		letter-spacing: 0;
	}

	.hero-line--bottom {
		font-family: var(--font-display);
		font-weight: 900;
		letter-spacing: -0.06em;
		/* Max raised 13.6rem → 13.75rem so PORTFOLIO width matches KONSTA KIVIOJA when KONSTA hits its 9rem cap */
		font-size: clamp(2.6rem, min(13.6vw, 23.5vh), 13.75rem);
		line-height: 0.82;
	}

	/* Layer 1: solid white KONSTA — sits behind the cutout photo so person blocks it visually */
	.hero-layer--back .hero-line--top {
		color: #ffffff;
	}

	/* PORTFOLIO on the back layer is a structural placeholder — actual PORTFOLIO sits on the front layer */
	.hero-layer--back .hero-line--bottom {
		visibility: hidden;
	}

	/* Layer 3: stencil outline ONLY for KONSTA KIVIOJA — shows where it overlaps the photo.
	   Explicit position/z-index ensures the layer renders ON TOP of the photo
	   (DOM order alone is fragile when a parent has a stacking-context-creating filter). */
	.hero-layer--front {
		position: relative;
		z-index: 3;
	}
	.hero-layer--photo {
		position: relative;
		z-index: 2;
	}
	.hero-layer--back {
		position: relative;
		z-index: 1;
	}
	.hero-layer--front .hero-line--top {
		color: transparent;
		-webkit-text-stroke: 1.8px #ffffff;
		text-stroke: 1.8px #ffffff;
	}

	/* PORTFOLIO sits on the FRONT layer — fully visible on top of the photo */
	.hero-layer--front .hero-line--bottom {
		visibility: visible;
		color: #ffffff;
		-webkit-text-stroke: 0;
		text-stroke: 0;
	}

	@media (max-width: 720px) {
		.hero-layer--front .hero-line--top {
			-webkit-text-stroke-width: 1px;
		}
	}

	/* Layer 2: person photo — bottom-aligned to grid cell so its bottom lines up with PORTFOLIO baseline */
	.hero-layer--photo {
		pointer-events: none;
		align-items: center;
		justify-content: flex-end;
		height: auto;
	}

	.hero-layer--photo img {
		display: block;
		width: auto;
		/* Photo fills hero from PORTFOLIO baseline up behind the masthead (top ~12px sits behind blurred masthead). */
		height: min(1000px, calc(100dvh - 7.5rem));
		max-width: 92vw;
		object-fit: contain;
		object-position: bottom;
		filter:
			grayscale(0.9)
			contrast(1.35)
			brightness(0.62)
			drop-shadow(0 30px 60px rgba(0, 0, 0, 0.55));
	}

	@media (max-width: 760px) {
		.hero-layer--photo img {
			height: clamp(200px, 48vh, 440px);
		}
	}

	/* When fallback JPG used: fade edges via radial mask so white bg disappears */
	.hero-layer--photo img.hero-photo-fallback {
		filter: grayscale(0.55) contrast(1.08) brightness(0.92) saturate(0.6);
		-webkit-mask-image: radial-gradient(
			ellipse 52% 70% at 50% 42%,
			#000 24%,
			#000 52%,
			rgba(0, 0, 0, 0.6) 72%,
			transparent 95%
		);
		mask-image: radial-gradient(
			ellipse 52% 70% at 50% 42%,
			#000 24%,
			#000 52%,
			rgba(0, 0, 0, 0.6) 72%,
			transparent 95%
		);
	}

	/* Hero entrance animation — Jakub recipe (opacity + translateY + blur) */
	@keyframes hero-rise {
		from {
			opacity: 0;
			transform: translateY(20px);
			filter: blur(6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
			filter: blur(0);
		}
	}

	.hero-stack,
	.hero-ticker {
		animation: hero-rise 800ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
	}

	.hero-ticker {
		animation-delay: 220ms;
	}

	/* ========== HERO TICKER — moves horizontally driven by vertical scroll ========== */
	.hero-ticker {
		position: absolute;
		bottom: 1.6rem;
		left: 0;
		right: 0;
		overflow: hidden;
		pointer-events: none;
		mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
		-webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
	}

	.hero-ticker-track {
		display: inline-flex;
		gap: 1.25rem;
		white-space: nowrap;
		transform: translate3d(calc(var(--ticker-x, 0) * 1px - 40%), 0, 0);
		will-change: transform;
	}

	.ticker-tag {
		flex-shrink: 0;
		font-family: var(--font-sans);
		font-size: 0.78rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--ink-mid);
	}

	.ticker-tag::after {
		content: '·';
		margin-left: 1.25rem;
		color: var(--ink-faint);
	}

	/* ========== BANDS (sections) ========== */
	/* One smooth pipe — sections flow into each other, no visible dividers, all left-aligned */
	.band {
		position: relative;
		max-width: 1280px;
		margin: 0;
		padding: clamp(4rem, 9vw, 7.5rem) clamp(1.5rem, 4vw, 3rem) clamp(3rem, 6vw, 5rem);
	}

	.band + .band {
		padding-top: 0;
	}

	.band--standfirst {
		text-align: left;
		padding-top: clamp(2rem, 5vw, 4rem);
		padding-bottom: clamp(6rem, 11vw, 10rem);
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 2.5rem;
	}


	.standfirst {
		max-width: 60ch;
		margin: 0;
		font-size: clamp(1.1rem, 1.6vw, 1.5rem);
		font-weight: 500;
		line-height: 1.55;
		letter-spacing: 0;
		color: var(--ink-mid);
	}

	.standfirst .word {
		display: inline-block;
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 700ms cubic-bezier(0.2, 0.7, 0.2, 1), transform 700ms cubic-bezier(0.2, 0.7, 0.2, 1);
	}

	.standfirst.in-view .word {
		opacity: 1;
		transform: none;
	}

	.standfirst.in-view .word {
		transition-delay: calc(var(--i, 0) * 50ms);
	}

	.standfirst-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		justify-content: flex-start;
	}

	/* Shared band-head — no hard divider, sits soft inside the flowing pipe */
	.band-head {
		display: block;
		margin-bottom: 2.8rem;
	}

	/* Numerointi piilossa — sivu on yksi kokonaisuus */
	.band-num {
		display: none;
	}

	.display {
		margin: 0;
		font-size: clamp(2.6rem, 6vw, 5.5rem);
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: -0.035em;
		color: var(--ink-hi);
		cursor: default;
	}

	/* Interactive headings: each letter reacts to cursor proximity.
	   linear(...) approximates a subtle spring — slight overshoot then settle, fits the portfolio's playful tone.
	   :global() because .char spans are created by JS after Astro's scoped style is applied. */
	.display :global(.char) {
		display: inline-block;
		transition:
			transform 360ms linear(0, 0.45, 0.85, 1.05 60%, 1.02, 1),
			color 320ms ease,
			text-shadow 320ms ease;
		will-change: transform;
	}

	.display :global(.char.space) {
		width: 0.28em;
	}

	.display:hover :global(.char) {
		color: var(--ink-hi);
	}

	.display :global(.char.hot) {
		color: var(--accent);
		text-shadow: 0 0 28px rgba(108, 210, 255, 0.5);
	}

	@media (max-width: 720px) {
		.band-head {
			margin-bottom: 2rem;
		}
	}

	.lead {
		font-size: clamp(1.2rem, 1.6vw, 1.45rem);
		line-height: 1.5;
		font-weight: 500;
		color: var(--ink-hi);
		max-width: 56ch;
		margin: 0 0 1.5rem;
	}

	.prose {
		font-size: 1.05rem;
		line-height: 1.85;
		color: var(--ink-mid);
		max-width: 64ch;
		margin: 0 0 3rem;
	}

	/* ========== BUTTONS ========== */
	.button {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.95rem 1.6rem;
		border-radius: 999px;
		font-weight: 600;
		font-size: 0.94rem;
		letter-spacing: 0.04em;
		text-decoration: none;
		transition: transform 200ms ease, box-shadow 200ms ease, background 200ms ease;
		cursor: pointer;
		border: none;
		font-family: var(--font-sans);
	}

	.button.primary {
		background: var(--accent);
		color: var(--bg-0);
		box-shadow: 0 16px 48px rgba(108, 210, 255, 0.3);
	}

	.button.primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 18px 54px rgba(108, 210, 255, 0.45);
	}

	.button.ghost {
		background: transparent;
		color: var(--ink-hi);
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	.button.ghost:hover {
		background: rgba(255, 255, 255, 0.06);
		border-color: rgba(255, 255, 255, 0.4);
	}

	/* Pillars / pillar / pillar-num CSS removed — markup no longer renders these. */

	@media (max-width: 880px) {
		/* (placeholder for future column overrides if needed) */
	}

	/* ========== TWO COL (kokemus + skills) ========== */
	.two-col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 5vw, 5rem);
	}

	/* Sentence-case col-label — removed tracked uppercase to break the repeated-label slop pattern.
	   Hierarchy comes from weight + size now, not from caps + tracking. */
	.col-label {
		display: block;
		margin: 0 0 1.25rem;
		font-family: var(--font-sans);
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.005em;
		color: var(--ink-hi);
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--rule);
	}

	.entries {
		list-style: none;
		padding: 0;
		margin: 0;
		counter-reset: entry;
	}

	.entries li {
		counter-increment: entry;
		display: grid;
		grid-template-columns: 2.5rem auto 1fr;
		column-gap: 1.5rem;
		align-items: baseline;
		padding: 1.1rem 0;
		border-bottom: 1px dashed var(--rule);
		transition: padding-left 220ms ease, background 220ms ease;
	}

	.entries li::before {
		content: counter(entry, decimal-leading-zero);
		font-family: var(--font-sans);
		font-size: 0.72rem;
		color: var(--ink-faint);
	}

	.entries li:hover {
		padding-left: 0.6rem;
	}

	.entry-role {
		display: block;
		color: var(--ink-hi);
		font-size: 1.02rem;
		font-weight: 500;
	}

	.entry-org {
		display: block;
		color: var(--ink-low);
		font-size: 0.88rem;
	}

	@media (max-width: 640px) {
		.entries li {
			grid-template-columns: 2.5rem 1fr;
		}
		.entry-org {
			grid-column: 2;
			margin-top: 0.2rem;
		}
	}

	.chips {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.chips li {
		padding: 0.7rem 1rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--rule);
		color: var(--ink-mid);
		font-size: 0.9rem;
		transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
	}

	.chips li:hover {
		background: rgba(108, 210, 255, 0.08);
		color: var(--ink-hi);
		border-color: rgba(108, 210, 255, 0.32);
	}

	@media (max-width: 880px) {
		.two-col {
			grid-template-columns: 1fr;
		}
	}

	/* ========== WORK ========== */
	.work-list {
		display: flex;
		flex-direction: column;
		border-top: 1px solid var(--rule);
	}

	.work {
		display: grid;
		grid-template-columns: minmax(80px, 110px) 1fr auto;
		gap: clamp(1rem, 3vw, 3rem);
		align-items: center;
		padding: clamp(1.8rem, 3.5vw, 2.6rem) 0;
		border-bottom: 1px solid var(--rule);
		color: var(--ink-hi);
		text-decoration: none;
		transition: padding 240ms ease;
	}

	a.work:hover {
		padding-left: clamp(0.4rem, 1vw, 1rem);
	}

	a.work:hover .work-index,
	a.work:hover .work-cta {
		color: var(--accent);
	}

	.work-index {
		font-family: var(--font-sans);
		font-size: 0.78rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--ink-low);
		transition: color 240ms ease;
	}

	.work-meta {
		min-width: 0;
	}

	.work-tag {
		display: inline-block;
		font-family: var(--font-sans);
		font-size: 0.7rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.8rem;
		padding: 0.25rem 0.65rem;
		background: rgba(108, 210, 255, 0.1);
		border-radius: 999px;
	}

	.work h3 {
		margin: 0 0 0.5rem;
		font-size: clamp(1.4rem, 2.4vw, 2.1rem);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.015em;
		color: var(--ink-hi);
	}

	.work p {
		margin: 0;
		color: var(--ink-mid);
		font-size: 0.98rem;
		line-height: 1.6;
		max-width: 58ch;
	}

	.work-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-family: var(--font-sans);
		font-size: 0.78rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-low);
		transition: color 240ms ease, gap 240ms ease;
	}

	a.work:hover .work-cta {
		gap: 0.7rem;
	}

	.work-cta.inert {
		opacity: 0.5;
	}

	@media (max-width: 760px) {
		.work {
			grid-template-columns: 1fr;
			gap: 0.6rem;
			padding: 1.6rem 0;
		}
		.work-cta {
			padding-top: 0.4rem;
		}
	}

	/* ========== CONTACT ========== */
	.band--contact {
		padding-bottom: 3rem;
	}

	.contact-stage {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
		padding: 2rem 0;
	}

	.contact-display {
		margin: 0.8rem 0 0;
		/* Match other section display headings */
		font-size: clamp(2.6rem, 6vw, 5.5rem);
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: -0.035em;
		color: var(--ink-hi);
	}

	.contact-lead {
		margin: 1.5rem 0 3rem;
		font-size: clamp(1.05rem, 1.3vw, 1.2rem);
		line-height: 1.55;
		color: var(--ink-mid);
		max-width: 50ch;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		width: 100%;
		max-width: 760px;
	}

	.contact-card {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-rows: auto auto;
		padding: 1.75rem 1.85rem;
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--rule);
		color: var(--ink-hi);
		text-decoration: none;
		text-align: left;
		transition: background 220ms ease, border-color 220ms ease, transform 220ms ease;
	}

	.contact-card:hover {
		background: rgba(108, 210, 255, 0.05);
		border-color: rgba(108, 210, 255, 0.3);
		transform: translateY(-2px);
	}

	.contact-card:hover .contact-arrow {
		transform: translate(4px, -4px);
		color: var(--accent);
	}

	.contact-label {
		grid-column: 1;
		grid-row: 1;
		font-family: var(--font-sans);
		font-size: 0.74rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.5rem;
	}

	.contact-card strong {
		grid-column: 1;
		grid-row: 2;
		font-size: clamp(1.05rem, 1.6vw, 1.35rem);
		font-weight: 600;
		color: var(--ink-hi);
	}

	.contact-arrow {
		grid-column: 2;
		grid-row: 1 / span 2;
		align-self: center;
		font-size: 1.4rem;
		color: var(--ink-low);
		transition: transform 240ms ease, color 240ms ease;
	}

	@media (max-width: 720px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
	}

	/* ========== COLOPHON ========== */
	.colophon {
		max-width: 1280px;
		margin: 5rem auto 0;
		padding: 2rem clamp(1.5rem, 4vw, 3rem);
		border-top: 1px solid var(--rule);
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		font-family: var(--font-sans);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		color: var(--ink-low);
	}

	.colophon a {
		color: var(--ink-low);
		text-decoration: none;
		transition: color 200ms ease;
	}

	.colophon a:hover {
		color: var(--accent);
	}

	.colophon .license-link {
		font-size: 0.62rem;
		letter-spacing: 0.18em;
		opacity: 0.3;
		transition: opacity 200ms ease, color 200ms ease;
	}

	.colophon .license-link:hover {
		opacity: 0.8;
		color: var(--accent);
	}

	/* ========== REVEAL ON SCROLL — three-tier hierarchy ========== */
	/* Tertiary tier (default for data-reveal) — minimal, fast, no blur.
	   Stops the "uniform-fade-in-on-every-element" anti-pattern. */
	[data-reveal] {
		opacity: 0;
		transform: translateY(8px);
		transition: opacity 240ms ease-out, transform 240ms ease-out;
	}

	/* Secondary tier — section headings and lead paragraphs. Moderate motion + slight blur. */
	[data-reveal][data-reveal-tier="secondary"],
	.band-head[data-reveal],
	.standfirst[data-reveal],
	.contact-stage[data-reveal] {
		transform: translateY(16px);
		filter: blur(3px);
		transition: opacity 500ms cubic-bezier(0.2, 0.7, 0.2, 1),
			transform 500ms cubic-bezier(0.2, 0.7, 0.2, 1),
			filter 500ms ease-out;
	}

	/* Primary tier — explicit hero-class content. Full Jakub recipe. */
	[data-reveal][data-reveal-tier="primary"] {
		transform: translateY(24px);
		filter: blur(6px);
		transition: opacity 700ms cubic-bezier(0.2, 0.7, 0.2, 1),
			transform 700ms cubic-bezier(0.2, 0.7, 0.2, 1),
			filter 700ms ease-out;
	}

	[data-reveal].in-view {
		opacity: 1;
		transform: none;
		filter: blur(0);
	}

	/* ========== MOBILE TIGHTER SPACING (placed late so it overrides earlier rules) ========== */
	@media (max-width: 760px) {
		/* Revert hero text sizes to the previous (larger) values on mobile */
		.hero-line {
			font-size: clamp(2rem, min(10.48vw, 18vh), 10.5rem);
		}
		.hero-line--bottom {
			font-size: clamp(3rem, min(16vw, 27vh), 16rem);
		}

		/* Compact section padding so more sections fit on screen */
		.band {
			padding: 1rem clamp(1rem, 4vw, 1.5rem) 0.75rem;
		}

		/* Sections after standfirst get extra top padding to visually separate from previous section.
		   Overrides the desktop `.band + .band { padding-top: 0 }` rule (same specificity, later in source). */
		.band + .band {
			padding-top: 2.5rem;
		}

		.band--standfirst {
			padding-top: 1rem;
			padding-bottom: 1.5rem;
			gap: 1rem;
		}

		.standfirst {
			/* Same size as entry-role ("Markkinointipäällikkö" etc.) */
			font-size: 1.02rem;
			line-height: 1.45;
		}

		/* Tighter ticker so at least 3 tags fit in mobile viewport */
		.hero-ticker-track {
			gap: 0.5rem;
		}
		.ticker-tag {
			font-size: 0.55rem;
			letter-spacing: 0.08em;
		}
		.ticker-tag::after {
			margin-left: 0.5rem;
		}
		.hero-ticker {
			/* Reduce edge fade so more tags fit in visible area */
			mask-image: linear-gradient(90deg, transparent 0%, #000 3%, #000 97%, transparent 100%);
			-webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 3%, #000 97%, transparent 100%);
		}

		.display {
			font-size: clamp(1.6rem, 7vw, 2.6rem);
		}

		.band-head {
			margin-bottom: 1rem;
		}

		.lead {
			font-size: 1rem;
			line-height: 1.4;
			margin-bottom: 0.75rem;
		}

		.prose {
			font-size: 0.95rem;
			line-height: 1.55;
			margin-bottom: 1rem;
		}

		.entries li {
			padding: 0.7rem 0;
		}

		.chips {
			gap: 0.4rem;
		}

		.chips li {
			padding: 0.5rem 0.85rem;
			font-size: 0.85rem;
		}

		.col-label {
			margin-bottom: 0.75rem;
			padding-bottom: 0.5rem;
		}

		.two-col {
			gap: 1.5rem;
		}

		.work {
			padding: 1rem 0;
		}

		.work h3 {
			font-size: clamp(1.05rem, 4vw, 1.4rem);
		}

		.contact-grid {
			gap: 0.6rem;
		}

		.contact-card {
			padding: 1.1rem 1.2rem;
		}

		.contact-stage {
			padding: 0.5rem 0;
		}

		.contact-lead {
			margin: 0.75rem 0 1.5rem;
		}

		.colophon {
			margin-top: 2rem;
			padding: 1.25rem clamp(1rem, 4vw, 1.5rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		[data-reveal],
		.standfirst .word {
			opacity: 1;
			transform: none;
			filter: none;
			transition: none;
		}
		.hero-stack,
		.hero-ticker {
			animation: none;
			opacity: 1;
			transform: none;
			filter: none;
		}
		html {
			scroll-behavior: auto;
		}
	}
</style>

<script type="module">
	const hover = window.matchMedia('(hover: hover)').matches;
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	// ---------- Cursor light ----------
	const light = document.querySelector('.cursor-light');
	if (light && hover) {
		let tx = 0, ty = 0, cx = 0, cy = 0, raf = 0;
		const move = () => {
			cx += (tx - cx) * 0.18;
			cy += (ty - cy) * 0.18;
			light.style.transform = `translate(${cx}px, ${cy}px)`;
			raf = requestAnimationFrame(move);
		};
		document.addEventListener('pointermove', (e) => {
			tx = e.clientX;
			ty = e.clientY;
			if (!light.classList.contains('active')) light.classList.add('active');
			if (!raf) raf = requestAnimationFrame(move);
		});
		document.addEventListener('pointerleave', () => light.classList.remove('active'));
	}

	// ---------- Stagger word indices for standfirst reveal ----------
	document.querySelectorAll('.standfirst .word').forEach((w, i) => {
		w.style.setProperty('--i', i);
	});

	// (Old --hero-bottom JS removed — vertical-mark is now inside .post-hero, no measurement needed)

	// ---------- Hero ticker — scroll-driven horizontal translate ----------
	// Skip entirely if user prefers reduced motion — horizontal scroll-driven motion is a vestibular risk.
	const tickerTrack = document.querySelector('.hero-ticker-track');
	if (tickerTrack && !reducedMotion) {
		let tRaf = 0;
		const TICKER_MULT = 0.35; // scroll multiplier — higher = faster ticker
		const updateTicker = () => {
			tickerTrack.style.setProperty('--ticker-x', window.scrollY * TICKER_MULT);
			tRaf = 0;
		};
		window.addEventListener(
			'scroll',
			() => {
				if (!tRaf) tRaf = requestAnimationFrame(updateTicker);
			},
			{ passive: true }
		);
		updateTicker();
	}

	// ---------- Reveal on scroll ----------
	const reveals = document.querySelectorAll('[data-reveal]');
	if ('IntersectionObserver' in window) {
		const io = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('in-view');
						io.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
		);
		reveals.forEach((el) => io.observe(el));
	} else {
		reveals.forEach((el) => el.classList.add('in-view'));
	}

	// Hero mouse parallax — disabled by request

	// ---------- Interactive headings: split into chars + react to cursor ----------
	const displays = document.querySelectorAll('.display');
	displays.forEach((el) => {
		// Preserve markup: walk text nodes, wrap each char in <span>, keep <br> intact
		const wrap = (node) => {
			if (node.nodeType === 3) {
				const frag = document.createDocumentFragment();
				const text = node.nodeValue;
				for (const ch of text) {
					const span = document.createElement('span');
					if (ch === ' ' || ch === ' ') {
						span.className = 'char space';
						span.innerHTML = '&nbsp;';
					} else if (ch === '­') {
						// soft hyphen — keep, no wrap
						span.className = 'char';
						span.textContent = '­';
					} else {
						span.className = 'char';
						span.textContent = ch;
					}
					frag.appendChild(span);
				}
				node.parentNode.replaceChild(frag, node);
			} else if (node.nodeType === 1 && node.tagName !== 'BR') {
				Array.from(node.childNodes).forEach(wrap);
			}
		};
		Array.from(el.childNodes).forEach(wrap);
	});

	if (hover && !reducedMotion) {
		const ROOT_MARGIN = 140; // px of influence around cursor
		const MAX_LIFT = 18;
		const MAX_SCALE = 1.18;

		displays.forEach((el) => {
			const chars = el.querySelectorAll('.char');
			let raf = 0;
			let mx = 0, my = 0;
			let active = false;

			const apply = () => {
				chars.forEach((ch) => {
					const r = ch.getBoundingClientRect();
					const cx = r.left + r.width / 2;
					const cy = r.top + r.height / 2;
					const dx = mx - cx;
					const dy = my - cy;
					const dist = Math.sqrt(dx * dx + dy * dy);
					if (dist < ROOT_MARGIN) {
						const t = 1 - dist / ROOT_MARGIN;
						const tx = -dx * 0.12 * t;
						const ty = -MAX_LIFT * t;
						const scale = 1 + (MAX_SCALE - 1) * t;
						ch.style.transform = `translate(${tx.toFixed(2)}px, ${ty.toFixed(2)}px) scale(${scale.toFixed(3)})`;
						if (t > 0.55) ch.classList.add('hot');
						else ch.classList.remove('hot');
					} else if (ch.style.transform) {
						ch.style.transform = '';
						ch.classList.remove('hot');
					}
				});
				raf = 0;
			};

			el.addEventListener('pointermove', (e) => {
				mx = e.clientX;
				my = e.clientY;
				active = true;
				if (!raf) raf = requestAnimationFrame(apply);
			});

			el.addEventListener('pointerleave', () => {
				active = false;
				chars.forEach((ch) => {
					ch.style.transform = '';
					ch.classList.remove('hot');
				});
			});
		});
	}
</script>
